---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import '../styles/postDetail.css';

type Props = CollectionEntry<'weekly'>['data'] & { id: string };

const { id, title, description, date, updatedDate, heroImage, tags } = Astro.props;
---

<html lang="ko">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      .weekly-prose {
        width: 840px;
        max-width: 100%;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
        color: var(--text);
      }
      @media (max-width: 720px) {
        .weekly-prose {
          padding: 1.5rem 1rem 3rem;
        }
      }
    </style>
  </head>

  <body>
    <Header />
    <main id="main-content" tabindex="-1">
      <article>
        {
          heroImage && (
            <div class="hero-image">
              <img width={1020} height={510} src={heroImage} alt="" />
            </div>
          )
        }
        <div class="weekly-prose" data-pagefind-body>
          <div class="title">
            <h1>{title}</h1>
            <div class="date">
              <FormattedDate date={date} pagefindMeta />
              {
                updatedDate && (
                  <div class="last-updated-on">
                    Last updated on <FormattedDate date={updatedDate} />
                  </div>
                )
              }
            </div>
            {
              tags && tags.length > 0 && (
                <p class="post-tags">
                  {tags.map((t) => (
                    <a class="post-tag" href={`/tags/${encodeURIComponent(t)}/`}>
                      #{t}
                    </a>
                  ))}
                </p>
              )
            }
            <hr />
          </div>
          <slot />
          <RelatedPosts collection="weekly" id={id} tags={tags} />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
