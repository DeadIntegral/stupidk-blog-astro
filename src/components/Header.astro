---
import HeaderLink from './HeaderLink.astro';
import Search from './Search.astro';
import { SITE_TITLE } from '../consts';
---
<script async src="https://www.googletagmanager.com/gtag/js?id=G-Z0RKTW6K2K"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-Z0RKTW6K2K');
</script>
<header>
  <nav>
    <a class="brand" href="/">{SITE_TITLE}</a>
    <div class="internal-links">
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/weekly">Weekly</HeaderLink>
      <HeaderLink href="/archive">Archive</HeaderLink>
    </div>
    <div class="search">
      <Search />
    </div>
    <div class="social-links">
      <a href="https://github.com/deadintegral/stupidk-blog-astro" target="_blank" aria-label="GitHub">
        <span class="sr-only">Go to GitHub repo</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
          ><path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path></svg
        >
      </a>
    </div>
  </nav>
</header>
<style>
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    margin: 0;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--border);
  }
  nav {
    width: var(--content-width-wide);
    max-width: 100%;
    margin: 0 auto;
    padding: 0 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    height: 56px;
  }
  .brand {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text);
    text-decoration: none;
    margin-right: 0.5rem;
    white-space: nowrap;
  }
  .brand:hover {
    color: var(--text);
    text-decoration: none;
  }
  .internal-links {
    display: flex;
    flex: 1;
    gap: 0.25rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .internal-links::-webkit-scrollbar { display: none; }
  nav a {
    display: inline-flex;
    align-items: center;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .internal-links a {
    padding: 0.45rem 0.7rem;
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
    font-weight: 500;
    height: 36px;
  }
  .internal-links a:hover {
    color: var(--text);
    background: var(--bg-soft);
    text-decoration: none;
  }
  .internal-links a.active {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    text-decoration: none;
    font-weight: 600;
  }
  .search {
    display: flex;
    align-items: center;
  }
  .social-links {
    display: flex;
  }
  .social-links a {
    color: var(--text-muted);
    padding: 0.4rem;
    border-radius: var(--radius-sm);
  }
  .social-links a:hover {
    color: var(--text);
    background: var(--bg-soft);
  }
  @media (max-width: 720px) {
    nav {
      padding: 0 0.9rem;
      gap: 0.35rem;
    }
    .internal-links a {
      padding: 0.4rem 0.55rem;
      font-size: 0.9rem;
    }
    .social-links {
      display: none;
    }
  }
</style>
