---
import HeaderLink from './HeaderLink.astro';
import Search from './Search.astro';
import { SITE_TITLE } from '../consts';
---
<script async src="https://www.googletagmanager.com/gtag/js?id=G-Z0RKTW6K2K"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-Z0RKTW6K2K');
</script>
<a class="skip-link" href="#main-content">본문으로 건너뛰기</a>
<header transition:persist="site-header">
  <nav>
    <a class="brand" href="/">{SITE_TITLE}</a>
    <div class="internal-links">
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/weekly">Weekly</HeaderLink>
      <HeaderLink href="/archive">Archive</HeaderLink>
      <HeaderLink href="/tags">Tags</HeaderLink>
    </div>
    <div class="search">
      <Search />
    </div>
    <button id="theme-toggle" class="theme-toggle" type="button" aria-label="테마 전환" data-tip="테마 전환">
      <svg class="i-system" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="3" width="20" height="14" rx="2"></rect>
        <path d="M8 21h8M12 17v4"></path>
      </svg>
      <svg class="i-light" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5 19 19M19 5l-1.5 1.5M6.5 17.5 5 19"></path>
      </svg>
      <svg class="i-dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.8A8 8 0 1 1 11.2 3 6 6 0 0 0 21 12.8z"></path>
      </svg>
    </button>
    <div class="social-links">
      <a href="https://github.com/deadintegral/stupidk-blog-astro" target="_blank" aria-label="GitHub">
        <span class="sr-only">Go to GitHub repo</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
          ><path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path></svg
        >
      </a>
    </div>
  </nav>
</header>

<script>
  const KEY = 'theme';
  const order = ['system', 'light', 'dark'];
  const html = document.documentElement;
  const btn = document.getElementById('theme-toggle');
  const labels: Record<string, string> = { system: '시스템', light: '라이트', dark: '다크' };

  const get = () => {
    try {
      return localStorage.getItem(KEY) || 'system';
    } catch {
      return 'system';
    }
  };
  const store = (m: string) => {
    try {
      m === 'system' ? localStorage.removeItem(KEY) : localStorage.setItem(KEY, m);
    } catch {}
  };
  const apply = (m: string) => {
    if (m === 'system') delete html.dataset.theme;
    else html.dataset.theme = m;
    const text = `테마 전환 · 현재: ${labels[m]}`;
    btn?.setAttribute('aria-label', text);
    btn?.setAttribute('data-tip', text);
  };

  apply(get());
  btn?.addEventListener('click', () => {
    const next = order[(order.indexOf(get()) + 1) % order.length];
    store(next);
    apply(next);
  });

  // 뷰 트랜지션 후 <html> 속성이 초기화될 수 있어 테마를 다시 적용한다(플래시 방지).
  document.addEventListener('astro:after-swap', () => apply(get()));
</script>

<script>
  // 헤더는 transition:persist 로 유지되므로(테마·검색 리스너 보존) 활성 네비 링크가
  // 서버 렌더로는 갱신되지 않는다. 전환 때마다 현재 경로 기준으로 다시 표시한다.
  function updateActiveNav() {
    const path = location.pathname;
    document.querySelectorAll<HTMLAnchorElement>('.internal-links a').forEach((a) => {
      const href = a.getAttribute('href') || '';
      const active = href !== '/' ? path.startsWith(href) : path === '/';
      a.classList.toggle('active', active);
    });
  }
  document.addEventListener('astro:page-load', updateActiveNav);

  // SPA 전환 시 GA4 페이지뷰 전송 (astro:after-swap 은 최초 로드엔 발동하지 않아 중복 없음)
  document.addEventListener('astro:after-swap', () => {
    const g = (window as any).gtag;
    if (typeof g === 'function') {
      g('event', 'page_view', {
        page_path: location.pathname + location.search,
        page_location: location.href,
        page_title: document.title,
      });
    }
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    margin: 0;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--border);
  }
  nav {
    width: var(--content-width-wide);
    max-width: 100%;
    margin: 0 auto;
    padding: 0 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    height: 56px;
  }
  .brand {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text);
    text-decoration: none;
    margin-right: 0.5rem;
    white-space: nowrap;
  }
  .brand:hover {
    color: var(--text);
    text-decoration: none;
  }
  .internal-links {
    display: flex;
    flex: 1;
    gap: 0.25rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .internal-links::-webkit-scrollbar { display: none; }
  nav a {
    display: inline-flex;
    align-items: center;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .internal-links a {
    padding: 0.45rem 0.7rem;
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
    font-weight: 500;
    height: 36px;
  }
  .internal-links a:hover {
    color: var(--text);
    background: var(--bg-soft);
    text-decoration: none;
  }
  .internal-links a.active {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    text-decoration: none;
    font-weight: 600;
  }
  .search {
    display: flex;
    align-items: center;
  }
  .theme-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .theme-toggle:hover {
    color: var(--text);
    background: var(--bg-soft);
    border-color: var(--border-strong);
  }
  /* 커스텀 툴팁: 네이티브 title 보다 빠르게 표시 */
  .theme-toggle::after {
    content: attr(data-tip);
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    z-index: 60;
    white-space: nowrap;
    padding: 0.3rem 0.5rem;
    font-size: 0.75rem;
    line-height: 1.3;
    color: var(--bg);
    background: var(--text);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-md);
    opacity: 0;
    transform: translateY(-3px);
    pointer-events: none;
    transition: opacity 0.12s ease, transform 0.12s ease;
  }
  .theme-toggle:hover::after,
  .theme-toggle:focus-visible::after {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .theme-toggle::after {
      transition: none;
    }
  }
  .social-links {
    display: flex;
  }
  .social-links a {
    color: var(--text-muted);
    padding: 0.4rem;
    border-radius: var(--radius-sm);
  }
  .social-links a:hover {
    color: var(--text);
    background: var(--bg-soft);
  }
  @media (max-width: 720px) {
    nav {
      padding: 0 0.9rem;
      gap: 0.35rem;
    }
    .internal-links a {
      padding: 0.4rem 0.55rem;
      font-size: 0.9rem;
    }
    .social-links {
      display: none;
    }
  }
</style>
