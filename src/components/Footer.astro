---
const today = new Date();
---

<footer>
  <div class="inner">
    <span class="copy">&copy; {today.getFullYear()} deadintegral</span>
    <div class="social-links">
      <a href="/rss.xml" aria-label="RSS feed">
        <span class="sr-only">RSS feed</span>
        <svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18" fill="currentColor"
          ><path d="M6.18 15.64a2.18 2.18 0 1 1 0 4.36 2.18 2.18 0 0 1 0-4.36zM4 4.44A19.56 19.56 0 0 1 19.56 20h-2.83A16.73 16.73 0 0 0 4 7.27V4.44zm0 5.66a13.9 13.9 0 0 1 9.9 9.9h-2.83A11.07 11.07 0 0 0 4 12.93V10.1z" /></svg
        >
      </a>
      <a href="https://github.com/deadintegral/stupidk-blog-astro" target="_blank" aria-label="GitHub">
        <span class="sr-only">Go to GitHub repo</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
          ><path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path></svg
        >
      </a>
    </div>
  </div>
</footer>
<style>
  footer {
    border-top: 1px solid var(--border);
    margin-top: 3rem;
    color: var(--text-muted);
    font-size: 0.875rem;
  }
  .inner {
    width: var(--content-width-wide);
    max-width: 100%;
    margin: 0 auto;
    padding: 1.5rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .social-links {
    display: flex;
    gap: 0.5rem;
  }
  .social-links a {
    display: inline-flex;
    align-items: center;
    color: var(--text-muted);
    padding: 0.35rem;
    border-radius: var(--radius-sm);
  }
  .social-links a:hover {
    color: var(--text);
    background: var(--bg-soft);
    text-decoration: none;
  }
  @media (max-width: 720px) {
    .inner {
      padding: 1.25rem 1rem;
    }
  }
</style>
