---
import FormattedDate from './FormattedDate.astro';
import { getRelatedPosts, postHref, type TagCollection } from '../utils/tags';

interface Props {
  collection: TagCollection;
  id: string;
  tags?: string[];
}

const { collection, id, tags = [] } = Astro.props;
const related = await getRelatedPosts({ collection, id, tags }, 5);
---

{
  related.length > 0 && (
    <section class="related" data-pagefind-ignore>
      <h2 class="related-title">관련 글</h2>
      <ul class="related-list">
        {related.map((post) => (
          <li>
            <a href={postHref(post)}>
              <span class="r-title">{post.title}</span>
              <span class="r-meta">
                <span class={`r-badge r-badge-${post.collection}`}>{post.collection}</span>
                <FormattedDate date={post.date} />
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}

<style>
  .related {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .related-title {
    margin: 0 0 0.75rem;
    font-size: 1.05rem;
    font-weight: 700;
  }
  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .related-list li a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.9rem;
    padding: 0.55rem 0.4rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--text);
  }
  .related-list li a:hover {
    background: var(--bg-soft);
    text-decoration: none;
  }
  .related-list li a:hover .r-title {
    color: var(--accent);
  }
  .r-title {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.92rem;
  }
  .r-meta {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-faint);
  }
  .r-badge {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.08rem 0.4rem;
    border-radius: 4px;
    color: var(--text-muted);
    background: var(--bg-soft);
    border: 1px solid var(--border);
  }
  .r-badge-weekly {
    color: var(--accent);
  }
</style>
